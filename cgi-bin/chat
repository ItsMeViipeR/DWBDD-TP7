#!/usr/bin/env python3
import os
import sys
import sqlite3
from construct_response import construct_response

script_dir = os.path.dirname(os.path.abspath(__file__))
db_path = os.path.join(script_dir, "chat.db")
html_path = os.path.join(script_dir, "..", "pages", "sendForm.html")

messages_html = ""
try:
    conn = sqlite3.connect(db_path)
    cursor = conn.cursor()
    cursor.execute(
        "CREATE TABLE IF NOT EXISTS messages (id INTEGER PRIMARY KEY AUTOINCREMENT, content TEXT, timestamp DATETIME DEFAULT CURRENT_TIMESTAMP)"
    )

    cursor.execute("SELECT content, timestamp FROM messages ORDER BY id DESC LIMIT 20")
    rows = cursor.fetchall()

    if rows:
        for row in rows:
            messages_html += f'<div class="msg" style="border-bottom: 1px solid #eee; padding: 5px;">'
            messages_html += f"<small>{row[1]}</small><br>{row[0]}</div>"
    else:
        messages_html = "<p>Aucun message dans la base de données.</p>"
    conn.close()
except Exception as e:
    messages_html = f"<p style='color:red'>Erreur SQLite : {str(e)}</p>"

try:
    with open(html_path, "r", encoding="utf-8") as f:
        html_content = f.read()  # On lit tout d'un coup
except Exception as e:
    html_content = f"<html><body>Erreur lecture HTML: {str(e)}</body></html>"

if 'id="chat-display"' in html_content:
    final_html = html_content.replace(
        'id="chat-display">', f'id="chat-display">{messages_html}'
    )
else:
    final_html = html_content.replace(
        "<body>", f'<body><div class="box">{messages_html}</div>'
    )

res = construct_response(200, final_html)
sys.stdout.buffer.write(res)
sys.stdout.buffer.flush()
